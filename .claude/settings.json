{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "ANTHROPIC_BASE_URL": "http://localhost:8317",
    "ANTHROPIC_AUTH_TOKEN": "claude-code",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "gpt-5.5",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "glm-5.1",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "gpt-5.4-mini",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_NO_FLICKER": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(cargo fmt:*)",
      "Bash(cargo clippy:*)",
      "Bash(pnpm *)",
      "Bash(uv *)",
      "Bash(pipx *)",
      "mcp__pencil"
    ]
  },
  "model": "opus[1m]",
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "ralph-loop@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "language": "Korean",
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "filesystem": {
      "allowWrite": [
        "/Users/koohyomin/.agents/.claude/.pnpm-store/v10",
        "/Users/koohyomin/.cache/uv",
        "/Users/koohyomin/.local/share/uv",
        "/Users/koohyomin/.local/share/pipx",
        "/Users/koohyomin/.local/bin",
        "/Users/koohyomin/.cache/pipx",
        "/Users/koohyomin/Library/Caches/pipx",
        "/Users/koohyomin/Library/Application Support/pipx"
      ],
      "allowRead": ["/Users/koohyomin/.gnupg"]
    },
    "enableWeakerNetworkIsolation": true
  },
  "effortLevel": "high",
  "plansDirectory": "./plans",
  "teammateMode": "tmux"
}
